#############
def ODE_full_PID(t, state):
    x, s, e, co2, vdk, T, Tc, I, F = state
    Tset = Tset_func(t)

    #------------------------PID Controller:-------------------------------------
    # Compute the Error:
    Error = T - Tset

    #Derivative Error
    derivative_error = 0

    # PID gains - to be tuned later....
    Kp = 0.05 ##### tune this!!!!
    Ki = 0.01
    Kd = 0.0

    # Update integral
    dI_dt = Error

    # Compute flowrate
    F = Kp*Error + Ki*I + Kd*derivative_error
    F = max(0, min(F, 0.5))  # constraint 0-0.5 m³/h (max of 500 L/hr)

    #------------------------------------------------------------------------------------

    mu_max_T = a_MB * np.log(T-273.15) +b_MB #these equations use temperature in degC
    r_vdk_T = c_MB * np.log(T-273.15) + d_MB #these equations use temperature in degC
    mu = mu_x(s, S_min, mu_max_T)

    # Mass Balances
    dx_dt   = (mu * x) - (g_x * x)
    ds_dt   = -k_s * mu * x
    de_dt   =  k_e * mu * x
    dco2_dt =  k_co2 * mu * x
    dvdk_dt =  k_v * mu * x - r_vdk_T * vdk

    # Heat Balance (Eq. 13) - Wort Temperature
    # dT/dt = (1/wort_density)(1/cp_wort)(ds/dt)(delta_H) + 1/(wort_volume * wort_density * cp_wort) * (Area * U) * (T_wort - T_water)
    #........continue from here..........

    # Modified Eq. 13 term 1 to multiply by 1/V_wort !!!! (removed 1/V_wort term 12/03/2026 - apparently implicit in volume (L)...?)
    # Multipied by 1000 to convert from L to m3
    # Undid the x1000, chatgpt said to 


    wort_temp_term1 = (ds_dt) * delta_H * (1/wort_density) * (1/wort_specific_heat_capacity) 
    # No conversion, g/L is the same as kg/m3 [units of wort_temp_term1 in units of K/hr]
    # should deltaH be negative or positive ????

    wort_temp_term2 = (Area) * (U_hr) * (1/(V_wort_m3 * wort_density * wort_specific_heat_capacity * 1000)) * (T-Tc) 
    # U is in J/m2 K hr
    # specific heat capacity is in kJ/kg K

    dT_dt = wort_temp_term1 - wort_temp_term2 # in Kelvin/hour (K/hr)
    # Changed from the terms being added to being subtracted
    # Sensible heat is removed
    # Changed to + because ChatGPT said to...


    water_temp_term1 = (F/Cooling_Jacket_Volume) * (T_water_in_K - Tc) # in K/hr

    water_temp_term2 = (Area * U_hr / (Cooling_Jacket_Volume * water_density * water_specific_heat_capacity * 1000)) * (T - Tc)
    # U is in J/m2 K hr

    K = Area * U_hr / (Cooling_Jacket_Volume * water_density * water_specific_heat_capacity * 1000)
    #print(f"Check Magnitude of K: {K:.2f}")

    TDF = T - Tc
    #print(f"The temperature driving force is:{TDF:.2f}")

    dTc_dt = water_temp_term1 + water_temp_term2 # in K/hr


    return dx_dt, ds_dt, de_dt, dco2_dt, dvdk_dt, dT_dt, dTc_dt, dI_dt, F

 

initial_conditions_all = [x0, s0, e0, co2_0, vdk_0, T0, Tc_0, I0, F0]

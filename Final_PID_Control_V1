i_d2 = np.searchsorted(t2nd, t_disturbance)
i_d1 = np.searchsorted(t1st, t_disturbance)

print("─── Performance metrics ─────────────────────────────────")
print(f"{'Metric':<40}  {'2nd-order':>10}  {'1st-order':>10}")
print(f"{'─'*40}  {'─'*10}  {'─'*10}")
print(f"{'IAE (full run), °C·hr':<40}  {iae(dev2):>10.2f}  {iae(dev1):>10.2f}")
print(f"{'Max |deviation|, °C':<40}  {np.max(np.abs(dev2)):>10.3f}  {np.max(np.abs(dev1)):>10.3f}")
post2 = dev2[i_d2:]; post1 = dev1[i_d1:]
print(f"{'Post-disturbance max |dev|, °C':<40}  {np.max(np.abs(post2)):>10.3f}  {np.max(np.abs(post1)):>10.3f}")
